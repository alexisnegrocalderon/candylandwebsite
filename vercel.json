{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build && pnpm run build:api",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/((?!assets/|candyland/|api/).*)", "destination": "/index.html" }
  ]
}
